{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/run-core-tests-on-stop.sh\"",
            "timeout": 600,
            "statusMessage": "Running :core:jvmTest before stop"
          }
        ]
      }
    ]
  }
}
