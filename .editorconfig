root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{kt,kts}]
# ktlint profile — opt OUT of every stylistic rule and opt IN only to rules
# that catch real bugs or unambiguous hygiene issues. The goal is to prevent
# new sources from drifting (unused imports, wildcard imports, mixed line
# endings) without churning the existing codebase every time ktlint updates.

# --- Disabled: formatter-driven layout rules. Auto-formatting touches too
#     many files for a single review to digest; individual authors can run
#     ktlintFormat locally but the CI gate stays focused. Note: `indent`
#     stays enabled because other rules (string-template-indent) depend on
#     it being loaded, and the existing 4-space codebase already complies.
ktlint_standard_string-template-indent = disabled
ktlint_standard_string-template = disabled
ktlint_standard_class-signature = disabled
ktlint_standard_function-signature = disabled
ktlint_standard_function-expression-body = disabled
ktlint_standard_multiline-expression-wrapping = disabled
ktlint_standard_multiline-if-else = disabled
ktlint_standard_multiline-loop = disabled
ktlint_standard_if-else-wrapping = disabled
ktlint_standard_chain-method-continuation = disabled
ktlint_standard_trailing-comma-on-call-site = disabled
ktlint_standard_trailing-comma-on-declaration-site = disabled
ktlint_standard_blank-line-before-declaration = disabled
ktlint_standard_no-empty-first-line-in-class-body = disabled
ktlint_standard_property-naming = disabled
ktlint_standard_max-line-length = disabled
ktlint_standard_package-name = disabled
ktlint_standard_statement-wrapping = disabled
ktlint_standard_wrapping = disabled
ktlint_standard_argument-list-wrapping = disabled
ktlint_standard_annotation = disabled
ktlint_standard_spacing-between-declarations-with-annotations = disabled
ktlint_standard_spacing-between-declarations-with-comments = disabled
ktlint_standard_no-multi-spaces = disabled
ktlint_standard_no-consecutive-comments = disabled
ktlint_standard_no-blank-line-in-list = disabled
ktlint_standard_comment-wrapping = disabled
# Compose @Composable functions use PascalCase by convention.
ktlint_standard_function-naming = disabled
# Wildcard imports are occasionally needed for kotlinx.serialization DSL /
# Compose helpers — gate them per-file via manual review, not ktlint.
ktlint_standard_no-wildcard-imports = disabled
# Filename-vs-single-class is noisy across KMP platform files (IosBridges.kt
# etc. exposes one class but is intentionally named after its module role).
ktlint_standard_filename = disabled

# --- Enabled: cheap, high-signal checks only.
ktlint_standard_no-unused-imports = enabled
ktlint_standard_no-trailing-spaces = enabled
ktlint_standard_final-newline = enabled
ktlint_standard_import-ordering = enabled

[*.{yml,yaml,json,md}]
indent_size = 2

[Makefile]
indent_style = tab
